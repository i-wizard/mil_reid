# =============================================================================
# Sample environment file for the animal re-identification ML core.
#
# Copy to `.env` and uncomment only what you want to override:
#     cp sample.env .env
#
# Every variable is OPTIONAL — each shows its built-in default (see ml/config.py).
# All are read by pydantic-settings with the `REID_` prefix. docker-compose loads
# `.env` automatically (env_file), or pass ad-hoc with: docker compose run -e VAR=...
# =============================================================================

# --- Storage layout (container paths under /app; these map to mounted volumes) ---
# Changing these in Docker is rarely needed — data/ and artifacts/ are bind-mounted.
#REID_DATA_ROOT=data
#REID_CACHE_ROOT=artifacts/feature_cache
#REID_ARTIFACTS_ROOT=artifacts

# --- Dataset / backbone / pooling ---
# REID_DATASET options: SeaTurtleIDHeads | IPanda50 | MacaqueFaces
#REID_DATASET=SeaTurtleIDHeads
# REID_BACKBONE options:
#   hf-hub:BVRA/MegaDescriptor-T-224  (wildlife foundation model, default)
#   vit_small_patch16_224             (generic ViT)
#   resnet50                          (fully offline timm fallback)
#REID_BACKBONE=hf-hub:BVRA/MegaDescriptor-T-224
# REID_POOLING options: GATED_ATTENTION (the MIL contribution) | MEAN (ablation baseline)
#REID_POOLING=GATED_ATTENTION

# --- Image / patch geometry ---
# REID_PATCH_RESOLUTION: UPSAMPLED (cheap; 56px patches upsampled by backbone)
#                        NATIVE    (each tile is full 224px detail; heavier precompute)
# NOTE: re-run precompute_features after changing this — cached embeddings differ.
#REID_PATCH_RESOLUTION=UPSAMPLED
#REID_IMAGE_SIZE=224          # UPSAMPLED-mode resize side (ignored in NATIVE mode)
#REID_PATCH_GRID=4            # tiles per side; bag holds patch_grid**2 patches
#REID_BACKBONE_INPUT_SIZE=224 # square input the backbone expects (drives NATIVE tiling)

# --- Backbone output / head geometry (feature_dim MUST match the backbone) ---
#REID_FEATURE_DIM=768         # 768 for MegaDescriptor-T / ViT-S; 2048 for resnet50
#REID_ATTENTION_DIM=128       # hidden width of the gated-attention scoring MLP
#REID_EMBEDDING_DIM=256       # final L2-normalized identity embedding width

# --- ArcFace (train-time only) ---
#REID_ARCFACE_MARGIN=0.5
#REID_ARCFACE_SCALE=30.0

# --- Training ---
#REID_EPOCHS=30
#REID_BATCH_SIZE=32
#REID_LEARNING_RATE=0.001
#REID_WEIGHT_DECAY=0.0001
#REID_NUM_WORKERS=0           # 0 is safest in containers; raise if CPU dataloading is the bottleneck
#REID_SEED=42

# --- Open-set retrieval ---
#REID_TOP_K=5                 # how many ranked candidates identify() returns
#REID_UNKNOWN_THRESHOLD=0.5   # cosine score below which the top match is rejected as a new individual

# --- Open-set split ---
#REID_OPEN_SET_RATIO=0.2      # fraction of identities held out as never-seen (tests the unknown threshold)
