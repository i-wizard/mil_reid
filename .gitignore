# Datasets and generated artifacts are large and reproducible — never commit them.
# Leading slash anchors these to the repo root so they DON'T also match the
# source package ml/data/ (which must be committed).
/data/
/artifacts/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# Local environment overrides (sample.env IS committed; .env is not)
.env

# OS / editor
.DS_Store
**/*.DS_Store

#Pycharm
.idea/
.claude/
